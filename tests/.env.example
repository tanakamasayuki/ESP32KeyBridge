# Profile-specific serial ports.
# These names match sketch.yaml profile names uppercased by pytest-embedded.

# ESP32-S3 board used only when single-board tests are requested.
# This board is not assumed to be connected all the time.
TEST_SERIAL_PORT_S3_SINGLE=/dev/ttyACM0

# Always-connected ESP32-S3 peer pair.
# HOST is the board running the USB Host side.
# DEVICE is the board running the USB Device side.
TEST_SERIAL_PORT_S3_PEER_HOST=/dev/ttyUSB0
TEST_SERIAL_PORT_PEER_DEVICE_S3_PEER_DEVICE=/dev/ttyUSB1

# Optional manual-test board. Manual tests may override this locally.
TEST_SERIAL_PORT_ESP32S3=/dev/ttyACM1

# pytest options to generate an HTML report.
#PYTEST_ADDOPTS="--html=report.html --self-contained-html"
